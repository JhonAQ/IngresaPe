# Database
DATABASE_URL="postgresql://<usuario>:<password>@localhost:5433/<base_de_datos>?schema=public"

# JWT Secret (cambiar por un string aleatorio fuerte en producción)
JWT_SECRET="<jwt_secret_seguro>"

# OAuth Google
GOOGLE_CLIENT_ID="<tu_google_client_id>.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="<tu_google_client_secret>"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# URL del frontend (usada para redirigir tras OAuth)
FRONTEND_URL="http://localhost:4200"

# Facebook (opcional)
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# Puerto del servidor (opcional, default 3000)
# PORT=3000
