generator client {
  provider = "prisma-client-js"
  // Genera el cliente de TypeScript para que el autocompletado funcione
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // PostgreSQL es necesario para soportar el tipo JSONB en las preguntas
}

// =========================================================
// 1. ENUMS (Valores fijos y reglas de negocio)
// =========================================================

// Roles de seguridad
enum Role {
  USER // Estudiante
  ADMIN // Tú y los fundadores (Control total)
  DATA_ENTRY // Data Squad (Solo pueden subir preguntas e inventario)
}

// Las 3 áreas académicas de la UNSA
enum Area {
  INGENIERIAS
  SOCIALES
  BIOMEDICAS
}

// Dificultad para equilibrar los simulacros
enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// Tipos de pregunta soportados por el motor extensible
enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE_SWIPE
  FLASHCARD
  ORDERING
  MATCHING
  FILL_IN_BLANK
}

// Planes de suscripción (Modelo de Negocio)
enum PlanType {
  MONTHLY // Plan "T-Rex" (S/ 9.90)
  ANNUAL // Plan "Cachimbo" (S/ 99.00)
}

// Estado de los pagos manuales (Yape/Plin)
enum PaymentStatus {
  PENDING // Foto enviada, esperando revisión del Admin
  APPROVED // Pago validado, beneficios activos
  REJECTED // Pago inválido o no recibido
}

// Origen de un intento de simulacro
enum ExamMode {
  ARCHIVE // Examen histórico completo
  GENERATED // Simulacro armado por el generador IA
}

// Estado de un intento de examen
enum ExamStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// Divisiones del ranking competitivo
enum Division {
  HUEVITO
  POLLITO
  DINOSAURIO
  FOSIL
  CACHIMBO
}

// Categorías de items de la tienda
enum ShopItemCategory {
  CONSUMABLE
  BOOST
  RATING
  COSMETIC
}

// =========================================================
// 2. IDENTIDAD Y PERFIL DEL ESTUDIANTE
// =========================================================

model User {
  // --- Datos Básicos ---
  id       String  @id @default(uuid())
  email    String  @unique
  name     String? // Ej: "Juan Pérez"
  password String? // Puede estar vacío si entra con Google
  image    String? // URL del avatar (Aquí guardaremos la foto de Google)

  // --- OAuth (NUEVO: Para Login Social) ---
  provider   String  @default("credentials") // 'google', 'facebook' o 'credentials'
  providerId String? // El ID único que nos da Google/Facebook para este usuario

  role      Role     @default(USER)
  createdAt DateTime @default(now())

  // --- Perfil Académico (CARRERA) ---
  // El usuario selecciona su carrera (ej: Civil), y a través de ella sabemos su Área.
  careerId String?
  career   Career? @relation(fields: [careerId], references: [id])

  // --- Gamificación (Stats rápidas para el Ranking) ---
  energy          Int       @default(25) // Moneda de juego (Max 25)
  coins           Int       @default(100) // DEPRECADO: migrar a gems
  gems            Int       @default(150) // Gemas para tienda y protectores
  inventory       String[]  @default(["default"]) // Lista de IDs de items comprados (legacy)
  lastRefill      DateTime  @default(now()) // Hora de última recarga automática
  totalXp         Int       @default(0) // Puntaje total (Leaderboard)
  streak          Int       @default(0) // Racha de días consecutivos
  lastInteraction DateTime  @default(now()) // Para comparar si jugó ayer u hoy

  // --- Sistema de Rating Competitivo ---
  rating              Int       @default(400)
  highestRating       Int       @default(400)
  division            Division  @default(HUEVITO)
  highestDivision     Division  @default(HUEVITO)
  seasonHighestRating Int       @default(400)
  seasonBestDivision  Division  @default(HUEVITO)
  riskFlags           String[]  @default([])
  ratingFrozenUntil   DateTime?

  // --- Estado Premium ---
  isPremium       Boolean   @default(false) // TRUE = Energía ilimitada
  subExpiresAt    DateTime? // Fecha de vencimiento de la suscripción

  // --- Simulacros ---
  lastExamScore          Float? // Último puntaje obtenido en un simulacro (0-100)
  freeSimAttemptsUsed    Int           @default(0) // Intentos free generados usados esta semana
  freeSimAttemptsResetAt DateTime? // Momento en que se reinicia el contador semanal
  attempts               ExamAttempt[] // Intentos de exámenes/simulacros

  // --- Historial y Relaciones ---
  progress        UserProgress[] // Avance por cursos
  nodeCompletions UserTopicNodeCompletion[] // Nodos completados por tema
  subscriptions   Subscription[] // Pagos realizados
  answers         AnswerLog[] // Respuestas dadas (Data para IA)
  ratingHistories RatingHistory[]
  seasonStandings SeasonStanding[]
  activityLogs    ActivityLog[]
  userItems       UserItem[]
}

// =========================================================
// 3. CATALOGO DE CARRERAS (Nueva Tabla)
// =========================================================

model Career {
  id           String @id @default(uuid())
  name         String // Ej: "Ingeniería Civil", "Medicina", "Derecho"
  area         Area // Ej: INGENIERIAS, BIOMEDICAS (Define qué cursos ve el usuario)
  minimumScore Float? // Puntaje mínimo histórico de ingreso (escala 0-100)

  users User[] // Lista de alumnos inscritos en esta carrera
}

// =========================================================
// 4. ACADEMIA (Inventario de Cursos y Preguntas)
// =========================================================

model Course {
  id      String  @id @default(uuid())
  name    String // Ej: "Química", "Álgebra"
  slug    String  @unique // Ej: "quimica" (URL friendly)
  iconUrl String? // Icono para el menú

  topics        Topic[] // Temas del curso
  progress      UserProgress[] // Progreso de los alumnos
  examQuestions ExamQuestion[] // Preguntas de exámenes históricos de este curso
}

model Topic {
  id      String @id @default(uuid())
  name    String // Ej: "Átomos", "Ecuaciones Lineales"
  slug    String // Ej: "atomos"
  order   Int // 1, 2, 3... (Orden del camino de aprendizaje)
  summary Json? // Resumen rico del tema: { introduccion, imagenUrl, puntosClave, formulaDestacada, tipExamen }

  // Nodos del tema: cada nodo es una lección de ~nodeSize preguntas.
  nodeSize  Int @default(7)
  nodeCount Int @default(1)

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  questions       Question[] // Banco de preguntas del tema
  examQuestions   ExamQuestion[] // Preguntas de exámenes históricos asociadas a este tema
  nodeCompletions UserTopicNodeCompletion[]
}

model Question {
  id         String       @id @default(uuid())
  type       QuestionType @default(MULTIPLE_CHOICE)
  statement  String // Enunciado (Soporta LaTeX $x^2$)
  imageUrl   String? // Imagen opcional
  difficulty Difficulty   @default(MEDIUM)

  // --- OPCIONES (JSONB) ---
  // Estructura: [{ "text": "A) 5", "isCorrect": false }, { "text": "B) 10", "isCorrect": true }]
  options Json?

  // --- CONTENT (JSONB) ---
  // Payload especifico por tipo de pregunta (discriminated union).
  // Ejemplo: { type: "MULTIPLE_CHOICE", options: [{ id, text, isCorrect }] }
  content Json?

  // --- FEEDBACK ---
  explanation String? // Explicación generada por IA para cuando fallan

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id])

  answers AnswerLog[]
}

// =========================================================
// 5. SEGUIMIENTO (Progreso y Analytics)
// =========================================================

// Avance de un usuario en un curso específico
model UserProgress {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  // IDs de temas completados (Estrellas obtenidas)
  completedTopicIds String[]

  currentXp Int @default(0) // XP ganado en este curso

  @@unique([userId, courseId]) // Solo un registro por curso/usuario
}

// Log individual de cada respuesta (Para detectar fallos y trampas)
model AnswerLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Una respuesta pertenece al banco de práctica (path) o a un examen histórico.
  questionId     String?
  question       Question?     @relation(fields: [questionId], references: [id])
  examQuestionId String?
  examQuestion   ExamQuestion? @relation(fields: [examQuestionId], references: [id])

  isCorrect      Boolean // ¿Acertó?
  selectedOption Int? // LEGACY: indice de la opcion seleccionada (0, 1, 2...)
  answer         Json? // Respuesta generica por tipo de pregunta
  timeTaken      Int? // Segundos que tardó en responder

  @@index([userId, questionId])
  @@index([userId, examQuestionId])
}

// =========================================================
// 5.5 EXÁMENES DE ADMISIÓN (Archivo histórico + simulacros)
// =========================================================

model Exam {
  id               String  @id @default(uuid())
  title            String // Ej: "Admisión UNSA 2024 - Fase I"
  year             Int
  phase            String? // "I", "II"
  type             String? // "ORDINARIO", "CEPRUNSA", "EXTRA"
  questionCount    Int
  timeLimitMinutes Int

  questions ExamQuestion[]
  attempts  ExamAttempt[]

  @@index([year, type])
}

model ExamQuestion {
  id     String @id @default(uuid())
  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  order  Int

  statement   String
  passage     String? // Texto base de comprensión lectora (RV)
  imageUrl    String? // Imagen opcional del enunciado
  options     Json // [{ id, text, isCorrect, imageUrl? }]
  explanation String?
  difficulty  Difficulty

  topicId  String
  topic    Topic  @relation(fields: [topicId], references: [id])
  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  answers AnswerLog[]

  @@index([examId, order])
  @@index([topicId])
}

model ExamAttempt {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  examId String? // null si es simulacro generado
  exam   Exam?    @relation(fields: [examId], references: [id])
  mode   ExamMode

  questionCount    Int
  timeLimitSeconds Int
  questionIds      String[] // IDs de ExamQuestion en orden
  answers          Json? // Record<examQuestionId, { selectedOptionId, timeTaken }>

  status          ExamStatus @default(IN_PROGRESS)
  startedAt       DateTime   @default(now())
  submittedAt     DateTime?
  timeUsedSeconds Int?

  // --- Evento oficial de ranking (fin de semana) ---
  isOfficial            Boolean   @default(false)
  seasonId              String?
  season                Season?   @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  timerStartedAt        DateTime?
  serverTimeLimitSec    Int       @default(7200) // 2 horas
  serverSubmittedAt     DateTime?
  isRevealed            Boolean   @default(false)
  calculatedScore       Float?
  calculatedRatingDelta Int?
  ratingHistory         RatingHistory?

  correctCount   Int?
  incorrectCount Int?
  blankCount     Int?
  score          Float? // 0-100

  totalXpEarned    Int @default(0)
  totalCoinsEarned Int @default(0)
  totalGemsEarned  Int @default(0)

  @@index([userId, status, startedAt])
  @@index([seasonId])
}

// =========================================================
// 5.6 RANKING COMPETITIVO (Seasons, rating, standings, actividad)
// =========================================================

model Season {
  id            String    @id @default(uuid())
  weekIndex     Int       @unique
  eventStartsAt DateTime
  eventEndsAt   DateTime
  revealedAt    DateTime?
  isActive      Boolean   @default(true)
  isRevealed    Boolean   @default(false)

  ratingHistories RatingHistory[]
  standings       SeasonStanding[]
  attempts        ExamAttempt[]

  @@index([isActive, isRevealed])
}

model RatingHistory {
  id                String   @id @default(uuid())
  createdAt         DateTime @default(now())
  appliedAt         DateTime?

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  examAttemptId     String?      @unique
  examAttempt       ExamAttempt? @relation(fields: [examAttemptId], references: [id], onDelete: Cascade)

  mode              ExamMode
  score             Float // 0-100
  oldRating         Int
  newRating         Int
  delta             Int
  divisionAtTime    Division
  kFactorUsed       Int
  avgOpponentRating Int
  protectorsUsed    String[] @default([])

  @@index([userId, createdAt])
  @@index([seasonId])
}

model SeasonStanding {
  id                  String   @id @default(uuid())
  seasonId            String
  season              Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  division            Division
  startOfSeasonRating Int
  endOfSeasonRating   Int
  bestRating          Int
  simulacrosCompleted Int     @default(0)
  rankInDivision      Int?

  @@unique([seasonId, userId])
  @@index([seasonId, division, rankInDivision])
}

model ActivityLog {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  simulacrosCompleted Int @default(0)
  questionsAnswered   Int @default(0)
  questionsCorrect    Int @default(0)
  nodesCompleted      Int @default(0)
  xpEarned            Int @default(0)
  gemsEarned          Int @default(0)
  loginBonusGems      Int @default(0)
  streakMilestoneGems Int @default(0)
  energyRefillsUsed   Int @default(0)

  @@unique([userId, date])
  @@index([userId, date])
}

model UserItem {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemKey   String // ej: RATING_SHIELD_50, RATING_FREEZE, RATING_BOOSTER
  quantity  Int       @default(0)
  expiresAt DateTime?

  @@unique([userId, itemKey])
  @@index([userId])
}

model ShopItem {
  id          String           @id @default(uuid())
  key         String           @unique
  name        String
  description String
  priceGems   Int
  maxQuantity Int? // límite por usuario (null = ilimitado)
  isActive    Boolean          @default(true)
  category    ShopItemCategory @default(CONSUMABLE)
  effectData  Json?
}

// Registro de nodos completados por usuario/tema (progreso estable del mapa)
model UserTopicNodeCompletion {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  nodeIndex Int

  @@unique([userId, topicId, nodeIndex])
  @@index([userId, topicId])
}

// =========================================================
// 6. FINANZAS (Suscripciones Manuales)
// =========================================================

model Subscription {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  plan     PlanType // Mensual o Anual
  amount   Float // Precio pagado (Histórico)
  proofUrl String? // Foto del voucher (Yape/Plin)

  status PaymentStatus @default(PENDING) // Pendiente -> Aprobado
}
