# Variables de entorno de Ingresa.pe
#
# IMPORTANTE: Las variables reales del backend deben configurarse en:
#   .env   (raíz del monorepo)
#
# NestJS / dotenv cargan el archivo desde el directorio de trabajo desde el que
# se ejecuta el servidor. Al usar Nx se corre desde la raíz del monorepo, por
# ejemplo:  npx nx serve api
#
# Este archivo (.env.example) es solo una plantilla. Copia su contenido a
# `.env` en la raíz y rellena los valores antes de iniciar el proyecto.
#
# Nunca commitees archivos .env con secretos.

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/ingresa_db"

# JWT Secret (cambiar en producción)
JWT_SECRET="cambia-esto-por-un-seguro-aleatorio"

# OAuth Google
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# URL del frontend (usada para redirigir tras OAuth)
FRONTEND_URL="http://localhost:4200"

# Facebook (opcional)
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
